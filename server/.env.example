# Copy this file to .env and fill in your values.
# The contact form falls back to logging messages if mail credentials are missing.

# Server
PORT=4000
NODE_ENV=development
# Comma separated list of allowed origins for CORS in production.
ALLOWED_ORIGINS=http://localhost:5173

# Email (optional, placeholder values).
# Any standard SMTP provider works (Resend, Postmark, SendGrid SMTP, Mailgun).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password

# Where contact form submissions should be sent.
CONTACT_TO=samloiterstein@gmail.com
CONTACT_FROM="Sam Loiterstein <noreply@sam-loiterstein.com>"
